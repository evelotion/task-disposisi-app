// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------
// ENUM (Pilihan Tetap/Dropdown System)
// -------------------------------------------------
enum Role {
  ADMIN
  KADEP
  STAF
}

enum Location {
  CABANG
  KP
  UNIT_KERJA
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  REVISION
  DONE
}

// -------------------------------------------------
// TABEL DATABASE
// -------------------------------------------------

model User {
  id        String    @id @default(cuid())
  nip       String    @unique // NIP jadi kunci unik buat login
  name      String
  phone     String
  password  String    // <--- TAMBAHIN BARIS INI BRO 🔥
  role      Role      @default(STAF) // Defaultnya adalah staf
  
  // Relasi: 1 User bisa punya banyak Task dan Log
  tasks     Task[]    @relation("AssignedTasks") 
  logs      TaskLog[] @relation("UserLogs")
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Task {
  id            String     @id @default(cuid())
  taskNumber    String     @unique // Contoh: TSK-001
  title         String
  description   String?
  attachmentUrl String?
  status        TaskStatus @default(PENDING)
  location      Location   @default(KP) // Dari request bos lu
  
  // Tanggal Follow Up dihapus, kita pakai createdAt sebagai tanggal submit otomatis
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relasi ke User (Siapa yang dikasih tugas)
  assigneeId    String
  assignee      User       @relation("AssignedTasks", fields: [assigneeId], references: [id])
  
  // Relasi ke tabel TaskLog (Riwayat progress)
  logs          TaskLog[]  @relation("TaskHistory")
}

model TaskLog {
  id            String   @id @default(cuid())
  message       String
  attachmentUrl String?  
  createdAt     DateTime @default(now())
  
  taskId        String
  // 🔥 Tambahin "TaskHistory" di sini biar sinkron sama tabel Task
  task          Task     @relation("TaskHistory", fields: [taskId], references: [id])
  
  userId        String
  // 🔥 Tambahin "UserLogs" di sini biar sinkron sama tabel User
  user          User     @relation("UserLogs", fields: [userId], references: [id])
}